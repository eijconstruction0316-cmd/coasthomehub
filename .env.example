# Google Gemini API
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Security & Session Signing
REPORT_SIGNING_SECRET=generate_a_random_32_character_string_here
ALLOW_MOCK_CHECKOUT=false

# Resend Email Configuration
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=noreply@coasthomehub.com.au
CONTACT_EMAIL=info@coasthomehub.com.au

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PRICE_FOUNDING=price_your_founding_member_price_id_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# App URL (Local / Production)
NEXT_PUBLIC_APP_URL=https://coasthomehub.com.au

# Database Configuration (Supabase / Neon / Local PostgreSQL)
# If provided, CoastHomeHub will automatically transition from local JSON file storage to PostgreSQL.
# DATABASE_URL=postgresql://username:password@localhost:5432/coasthomehub
